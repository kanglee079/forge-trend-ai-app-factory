# Core URLs
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Database
POSTGRES_USER=factory
POSTGRES_PASSWORD=factory
POSTGRES_DB=factory
DATABASE_URL=postgresql+psycopg://factory:factory@localhost:5432/factory
DOCKER_DATABASE_URL=postgresql+psycopg://factory:factory@postgres:5432/factory

# Queue
REDIS_URL=redis://localhost:6379/0
DOCKER_REDIS_URL=redis://redis:6379/0
PIPELINE_QUEUE_NAME=project_pipeline
FACTORY_BRIEF_QUEUE_NAME=factory_brief_queue
WORKER_STALE_SECONDS=60

# Storage
MINIO_ROOT_USER=factory
MINIO_ROOT_PASSWORD=factory123
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=factory-artifacts
LOCAL_ARTIFACT_ROOT=workspaces

# Secrets
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FACTORY_SECRET_KEY=replace-with-fernet-key

# Worker
WORKER_API_BASE_URL=http://localhost:8000
WORKER_WORKSPACE_ROOT=workspaces
WORKER_HEARTBEAT_SECONDS=15
WORKER_MAX_FIX_ITERATIONS=10
WORKER_NAME=local-worker
WORKER_CODE_PROVIDER=codex_cli
WORKER_CODEX_MODEL=
WORKER_CODEX_TIMEOUT_SECONDS=180
WORKER_ENABLE_CODEX=true

# Optional legal/low-volume web evidence for auto_trend mode.
# Comma-separated URLs, fetched only when the domain appears in RESEARCH_ALLOWED_DOMAINS.
RESEARCH_ALLOWED_URLS=
RESEARCH_ALLOWED_DOMAINS=github.com,pub.dev,producthunt.com,reddit.com
RESEARCH_WEB_TIMEOUT_SECONDS=8
RESEARCH_WEB_DELAY_SECONDS=1
